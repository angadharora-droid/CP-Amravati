# ---- Database ----
# Local MongoDB (what you run on your machine)
MONGO_URI=mongodb://127.0.0.1:27017/centrepoint_amravati

# ---- Auth ----
# Generate one:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-string

# ---- Admin account (used once, by `npm run seed:admin`) ----
ADMIN_EMAIL=desk@centrepointamravati.com
ADMIN_PASSWORD=change-this-password
ADMIN_NAME=Front Desk

# ---- Payments (Razorpay) ----
# Get these from the Razorpay dashboard → Settings → API Keys.
# Leave BOTH empty in development: the booking engine still works, but guests
# are told to pay at the hotel desk instead of paying online.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ---- Server ----
PORT=3001

# Comma-separated. Leave empty in dev to allow any origin.
# In production put your Vercel URL here.
CORS_ORIGINS=

FRONTEND_ORIGIN=http://localhost:5173
